# Server
PORT=3000
NODE_ENV=development

# Logging (debug | info | warn | error)
LOG_LEVEL=info

# Database
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=setulab

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=your_refresh_token_secret_here
REFRESH_TOKEN_EXPIRES_IN=7d

# Storage — set STORAGE_PROVIDER to switch connector: cloudinary | s3 | azure
STORAGE_PROVIDER=cloudinary

# Cloudinary (active when STORAGE_PROVIDER=cloudinary)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# AWS S3 (active when STORAGE_PROVIDER=s3)
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=

# Azure Blob Storage (active when STORAGE_PROVIDER=azure)
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=
