# Server
PORT=3000
NODE_ENV=development

# Logging (debug | info | warn | error)
LOG_LEVEL=info

# Database
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=setulab

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=your_refresh_token_secret_here
REFRESH_TOKEN_EXPIRES_IN=7d
