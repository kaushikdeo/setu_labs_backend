{
  "name": "setulab_backend",
  "version": "0.1.0",
  "description": "Company Standard Node.js + Express + TypeScript Template",
  "main": "dist/server.js",
  "scripts": {
    "dev": "cross-env NODE_ENV=development ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "cross-env NODE_ENV=production node dist/server.js",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write .",
    "test": "jest",
    "script:delete-users": "cross-env NODE_ENV=development ts-node --transpile-only scripts/delete-users.ts",
    "script:delete-visits": "cross-env NODE_ENV=development ts-node --transpile-only scripts/delete-visits.ts",
    "script:delete-all": "cross-env NODE_ENV=development ts-node --transpile-only scripts/delete-all.ts",
    "script:delete-operational": "cross-env NODE_ENV=development ts-node --transpile-only scripts/delete-operational.ts",
    "script:seed-test-types": "cross-env NODE_ENV=development ts-node --transpile-only src/scripts/seed-test-types.ts",
    "script:seed-instrument-links": "cross-env NODE_ENV=development ts-node --transpile-only src/scripts/seed-instrument-test-links.ts",
    "script:patch-test-configs": "cross-env NODE_ENV=development ts-node --transpile-only src/scripts/patch-test-type-configs.ts",
    "prepare": "node -e \"if (!process.env.CI && !process.env.VERCEL) require('child_process').execSync('husky install', {stdio:'inherit'})\"",
    "preinstall": "npx only-allow pnpm"
  },
  "keywords": [
    "nodejs",
    "express",
    "typescript",
    "template"
  ],
  "author": "Kaushik Deo",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "joi": "^17.12.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.6.2",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^18.4.4",
    "@commitlint/config-conventional": "^18.4.4",
    "@types/bcryptjs": "^3.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.10.6",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "cross-env": "^10.1.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.2",
    "husky": "^8.0.3",
    "jest": "^29.7.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.1.1",
    "supertest": "^7.2.2",
    "ts-jest": "^29.1.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "5.3.3"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,json,md}": [
      "prettier --write"
    ]
  }
}
